# Copy this file to .env and fill in your own free API keys.
# .env is gitignored — never commit real keys.

GROQ_API_KEY=
OILPRICEAPI_KEY=
AISSTREAM_API_KEY=

# How often the background agent loop runs, in seconds. 900 = 15 minutes.
PIPELINE_INTERVAL_SECONDS=900

# How many seconds to burst-sample AIS per corridor, per run.
AIS_SAMPLE_SECONDS=90

# Local dashboard port
PORT=5000
